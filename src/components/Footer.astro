---
import { useTranslations, localizedPath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = '2026';
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-name">Juan Manuel Ahumada Vázquez</span>
        <span class="footer-role">{t('site.role')}</span>
      </div>

      <nav class="footer-links" aria-label="Footer">
        <a href={localizedPath(lang, '/work')}>{t('nav.work')}</a>
        <a href={localizedPath(lang, '/case-studies')}>{t('nav.case_studies')}</a>
        <a href={localizedPath(lang, '/writing')}>{t('nav.writing')}</a>
        <a href={localizedPath(lang, '/contact')}>{t('nav.contact')}</a>
      </nav>

      <div class="footer-socials">
        <a href="https://github.com/jmav94" aria-label="GitHub" target="_blank" rel="noopener">GH</a>
        <a href="https://www.linkedin.com/in/jahumada94/" aria-label="LinkedIn" target="_blank" rel="noopener">IN</a>
        <a href="mailto:juan.ahumada94@gmail.com" aria-label="Email">@</a>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} · {t('site.location')}</span>
      <span class="footer-meta">{t('footer.tagline')}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rule);
    padding: 3rem 0 2rem;
    margin-top: 6rem;
    background: var(--bg-soft);
  }

  .footer-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr auto;
    gap: 2rem;
    align-items: start;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--rule);
  }

  .footer-brand { display: flex; flex-direction: column; gap: 0.25rem; }
  .footer-name {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--ink);
  }
  .footer-role {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
  }
  .footer-links a {
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--ink-2);
    text-decoration: none;
  }
  .footer-links a:hover { color: var(--accent); }

  .footer-socials { display: flex; gap: 0.5rem; }
  .footer-socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px; height: 32px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ink-2);
    text-decoration: none;
    border: 1px solid var(--rule-2);
    border-radius: 4px;
  }
  .footer-socials a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .footer-bottom {
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
  }

  @media (max-width: 700px) {
    .footer-top { grid-template-columns: 1fr; gap: 1.5rem; }
  }

  /* Touch targets — minimum 44px on coarse pointers */
  @media (pointer: coarse) {
    .footer-socials a { width: 44px; height: 44px; }
    .footer-links a { display: inline-flex; align-items: center; min-height: 44px; }
  }
</style>
