---
import { useTranslations, localizedPath, alternateLangPath, type Lang } from '../i18n/utils';
import { ui } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const alt = alternateLangPath(lang, Astro.url);

const nav = [
  { key: 'nav.work', path: '/work' },
  { key: 'nav.case_studies', path: '/case-studies' },
  { key: 'nav.writing', path: '/writing' },
  { key: 'nav.about', path: '/about' },
  { key: 'nav.contact', path: '/contact' },
] as const;

const more = [
  { key: 'nav.teaching', path: '/teaching' },
  { key: 'nav.uses', path: '/uses' },
] as const;

const resumeHref = lang === 'es' ? '/cv/cv-es.pdf' : '/cv/cv-en.pdf';
---

<header class="site-nav">
  <div class="nav-inner">
    <a href={localizedPath(lang, '/')} class="brand" aria-label="Home">
      <span class="brand-mark">JA</span>
      <span class="brand-name">Juan Ahumada</span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav-list">
        {nav.map(({ key, path }) => (
          <li><a href={localizedPath(lang, path)}>{t(key as any)}</a></li>
        ))}
        <li class="nav-more">
          <button type="button" id="more-toggle" class="nav-more-toggle" aria-expanded="false" aria-haspopup="true">
            {t('nav.more')}
            <svg class="more-caret" xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <ul class="nav-more-menu">
            {more.map(({ key, path }) => (
              <li><a href={localizedPath(lang, path)}>{t(key as any)}</a></li>
            ))}
          </ul>
        </li>
      </ul>
    </nav>

    <div class="nav-actions">
      <a href={resumeHref} class="nav-action" download>{t('nav.resume')}</a>
      <span class="nav-divider" aria-hidden="true"></span>
      <a href="https://github.com/jmav94" class="nav-action nav-action--icon" aria-label="GitHub" target="_blank" rel="noopener">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      </a>
      <a href="https://www.linkedin.com/in/jahumada94/" class="nav-action nav-action--icon" aria-label="LinkedIn" target="_blank" rel="noopener">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <span class="nav-divider" aria-hidden="true"></span>
      <a href={alt} class="nav-action" aria-label={t('nav.toggle_lang')}>
        {lang === 'en' ? 'ES' : 'EN'}
      </a>
      <button type="button" id="theme-toggle" class="nav-action theme-toggle" aria-label={t('nav.toggle_theme')}>
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>

    <button type="button" id="menu-toggle" class="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    border-bottom: 1px solid var(--rule);
  }

  /* Blur lives on a pseudo-element so .site-nav itself does NOT become the
     containing block for the fixed mobile-menu overlay (backdrop-filter on the
     element would trap position:fixed children inside the 64px bar). */
  .site-nav::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    pointer-events: none;
  }

  .nav-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    height: var(--nav-height);
    padding: 0 var(--space-6);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .brand:hover { color: var(--accent); }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 4px;
    background: var(--ink);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .brand-name { font-size: 0.95rem; }

  nav { flex: 1; display: flex; justify-content: center; }

  .nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.1rem;
  }

  .nav-list a {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink-2);
    text-decoration: none;
    letter-spacing: -0.005em;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .nav-list a:hover { color: var(--accent); }

  /* ===== "More" dropdown ===== */
  .nav-more { position: relative; }

  .nav-more-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink-2);
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    letter-spacing: -0.005em;
    white-space: nowrap;
    transition: color 0.15s ease;
  }
  .nav-more-toggle:hover { color: var(--accent); }
  .more-caret { transition: transform 0.18s ease; margin-top: 1px; }

  /* invisible bridge so the cursor can travel from button to menu without losing :hover */
  .nav-more::after {
    content: "";
    position: absolute;
    top: 100%;
    left: -0.5rem;
    right: -0.5rem;
    height: 0.7rem;
  }

  .nav-more-menu {
    position: absolute;
    top: calc(100% + 0.55rem);
    right: 0;
    min-width: 152px;
    list-style: none;
    margin: 0;
    padding: 0.35rem;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: 6px;
    box-shadow: 0 14px 30px -18px color-mix(in srgb, var(--ink) 45%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
    z-index: 60;
  }

  .nav-more:hover .nav-more-menu,
  .nav-more:focus-within .nav-more-menu,
  .nav-more.open .nav-more-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav-more:hover .more-caret,
  .nav-more:focus-within .more-caret,
  .nav-more.open .more-caret { transform: rotate(180deg); }

  .nav-more-menu li { display: block; }
  .nav-more-menu a {
    display: block;
    padding: 0.45rem 0.7rem;
    border-radius: 4px;
    font-size: 0.88rem;
    color: var(--ink-2);
    white-space: nowrap;
  }
  .nav-more-menu a:hover { background: var(--bg-soft); color: var(--accent); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .nav-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 38px;
    height: 32px;
    padding: 0 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--ink-2);
    background: transparent;
    border: 1px solid var(--rule-2);
    border-radius: 4px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.15s ease;
    letter-spacing: 0.02em;
  }

  .nav-action:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .nav-action--icon {
    min-width: 32px;
    width: 32px;
    padding: 0;
  }
  .nav-action--icon svg { display: block; }

  .nav-divider {
    width: 1px;
    height: 18px;
    background: var(--rule-2);
    margin: 0 0.15rem;
  }

  .theme-toggle .icon-moon { display: none; }
  :global([data-theme="dark"]) .theme-toggle .icon-sun { display: none; }
  :global([data-theme="dark"]) .theme-toggle .icon-moon { display: inline-block; }

  .menu-toggle {
    display: none;
    width: 32px;
    height: 32px;
    background: transparent;
    border: 1px solid var(--rule-2);
    border-radius: 4px;
    cursor: pointer;
    padding: 0;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
  }

  .menu-toggle span {
    display: block;
    width: 14px;
    height: 1.5px;
    background: var(--ink);
  }

  @media (max-width: 1024px) {
    nav, .nav-actions { display: none; }
    .menu-toggle { display: flex; }
    .nav-inner { justify-content: space-between; }
  }

  body.menu-open .site-nav nav {
    display: flex;
    position: fixed;
    inset: var(--nav-height) 0 0 0;
    background: var(--bg);
    padding: 2rem;
    border-top: 1px solid var(--rule);
  }

  body.menu-open .site-nav .nav-list {
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    align-items: center;
  }

  body.menu-open .site-nav .nav-list a {
    font-size: 1.25rem;
  }

  /* In the full-screen mobile menu, flatten "More": hide the toggle and
     let Teaching/Uses flow inline as regular items. */
  body.menu-open .nav-more,
  body.menu-open .nav-more-menu {
    display: contents;
    visibility: visible;
    opacity: 1;
  }
  body.menu-open .nav-more-toggle,
  body.menu-open .nav-more::after { display: none; }
  body.menu-open .nav-more-menu a {
    padding: 0;
    color: var(--ink-2);
  }

  body.menu-open .nav-actions {
    display: flex;
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 51;
  }

  body.menu-open .nav-divider { display: none; }

  /* Touch targets — WCAG 2.5.5 / Apple HIG minimum 44px on coarse pointers */
  @media (pointer: coarse) {
    .nav-action { height: 44px; min-height: 44px; }
    .nav-action--icon { width: 44px; min-width: 44px; }
    .menu-toggle { width: 44px; height: 44px; }
  }
</style>

<script is:inline>
  (function () {
    const STORAGE_KEY = 'theme';
    const html = document.documentElement;
    const saved = localStorage.getItem(STORAGE_KEY);
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const initial = saved || (prefersDark ? 'dark' : 'light');
    html.setAttribute('data-theme', initial);

    document.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      const themeBtn = target.closest('#theme-toggle');
      if (themeBtn) {
        const current = html.getAttribute('data-theme') || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem(STORAGE_KEY, next);
      }
      const menuBtn = target.closest('#menu-toggle');
      if (menuBtn) {
        document.body.classList.toggle('menu-open');
        const expanded = document.body.classList.contains('menu-open');
        menuBtn.setAttribute('aria-expanded', String(expanded));
      }

      // "More" dropdown: toggle on its button, close when clicking anywhere else
      const moreBtn = target.closest('#more-toggle');
      const moreWrap = document.querySelector('.nav-more');
      if (moreWrap) {
        if (moreBtn) {
          const open = moreWrap.classList.toggle('open');
          moreBtn.setAttribute('aria-expanded', String(open));
        } else if (!target.closest('.nav-more-menu')) {
          moreWrap.classList.remove('open');
          const btn = moreWrap.querySelector('#more-toggle');
          if (btn) btn.setAttribute('aria-expanded', 'false');
        }
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const moreWrap = document.querySelector('.nav-more.open');
      if (moreWrap) {
        moreWrap.classList.remove('open');
        const btn = moreWrap.querySelector('#more-toggle');
        if (btn) { btn.setAttribute('aria-expanded', 'false'); btn.focus(); }
      }
    });
  })();
</script>
