---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
const lang = 'en';
const t = useTranslations(lang);

const calUrl = 'https://cal.com/juan-ahumada';
const email = 'juan.ahumada94@gmail.com';
---

<BaseLayout title="Contact" description="Email, calendar, LinkedIn, GitHub — the channels I read and respond to." lang={lang}>
  <section class="container-narrow contact">
    <header class="page-head">
      <span class="eyebrow">{t('contact.eyebrow')}</span>
      <h1>{t('contact.title')}</h1>
      <p class="lead">{t('contact.lead')}</p>
    </header>

    <!-- ============= QUICK FIT (2 rows only) ============= -->
    <div class="fit-block">
      <header class="fit-head">
        <span class="fit-dot" aria-hidden="true"></span>
        <span class="fit-label">{t('contact.fit_header')}</span>
      </header>
      <ul class="fit-list">
        <li class="fit-row fit-row--strong">
          <span class="fit-row-label">{t('contact.fit_strong')}</span>
          <span class="fit-row-value">{t('contact.fit_strong_items')}</span>
        </li>
        <li class="fit-row">
          <span class="fit-row-label">{t('contact.fit_response')}</span>
          <span class="fit-row-value">{t('contact.fit_response_items')}</span>
        </li>
      </ul>
    </div>

    <!-- ============= PRIMARY: EMAIL ============= -->
    <a href={`mailto:${email}`} class="primary-card" aria-label="Send email">
      <span class="primary-email">{email}</span>
      <div class="primary-actions">
        <span class="primary-btn">{t('contact.primary_action')} →</span>
      </div>
      <p class="primary-reassurance">{t('contact.primary_reassurance')}</p>
      <span class="reg-mark reg-tl" aria-hidden="true"></span>
      <span class="reg-mark reg-tr" aria-hidden="true"></span>
      <span class="reg-mark reg-bl" aria-hidden="true"></span>
      <span class="reg-mark reg-br" aria-hidden="true"></span>
    </a>

    <!-- ============= TIP for better first messages ============= -->
    <aside class="tip">
      <span class="tip-label">{t('contact.tip_label')}</span>
      <p>{t('contact.tip_body')}</p>
    </aside>

    <!-- ============= SECONDARY: CALENDAR ============= -->
    <a href={calUrl} target="_blank" rel="noopener" class="secondary-card">
      <div class="secondary-text">
        <span class="secondary-label">{t('contact.call_label')}</span>
        <span class="secondary-action">{t('contact.call_action')} →</span>
        <span class="secondary-hint">{t('contact.call_hint')}</span>
      </div>
      <svg class="secondary-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
    </a>

    <!-- ============= OTHER CHANNELS ============= -->
    <div class="other-channels">
      <span class="other-label">{t('contact.other_label')}</span>
      <ul class="other-list">
        <li><a href="https://www.linkedin.com/in/jahumada94/" target="_blank" rel="noopener"><span class="ch-key">in</span> linkedin.com/in/jahumada94</a></li>
        <li><a href="https://github.com/jmav94" target="_blank" rel="noopener"><span class="ch-key">gh</span> github.com/jmav94</a></li>
        <li><a href="tel:+528677537160"><span class="ch-key">tel</span> +52 867 753 7160</a></li>
      </ul>
    </div>

    <p class="location">{t('contact.location')}</p>
  </section>
</BaseLayout>

<style>
  .contact { padding-top: 1rem; }
  .page-head { margin-bottom: 2.5rem; }
  .page-head h1 { margin-top: 1rem; }
  .page-head .lead { font-size: 1.1rem; color: var(--ink-2); max-width: 38rem; margin-top: 1rem; }

  /* ============================================
     QUICK FIT (just 2 rows now)
     ============================================ */
  .fit-block {
    margin-bottom: 1.5rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    overflow: hidden;
    background: var(--surface);
  }

  .fit-head {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 0.85rem;
    background: var(--bg-soft);
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-2);
    letter-spacing: 0.04em;
  }
  .fit-dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
  }

  .fit-list { list-style: none; margin: 0; padding: 0; }

  .fit-row {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    align-items: baseline;
    border-bottom: 1px dotted var(--rule);
  }
  .fit-row:last-child { border-bottom: 0; }
  .fit-row-label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }
  .fit-row--strong .fit-row-label { color: var(--accent); }
  .fit-row-value {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--ink);
    line-height: 1.5;
  }

  /* ============================================
     PRIMARY CARD - clean, no forced spec header
     ============================================ */
  .primary-card {
    display: block;
    position: relative;
    background: var(--accent-soft);
    border: 1.5px solid var(--accent);
    border-radius: 8px;
    padding: 1.5rem 1.75rem 1.25rem;
    margin-bottom: 0.85rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    box-shadow: 0 1px 0 var(--rule);
  }

  :global([data-theme="dark"]) .primary-card {
    background: color-mix(in srgb, var(--accent) 10%, var(--surface));
  }

  .primary-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -16px color-mix(in srgb, var(--accent) 55%, transparent);
    color: inherit;
  }

  .primary-email {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(1.05rem, 2.3vw, 1.4rem);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
    margin-bottom: 0.85rem;
    word-break: break-all;
  }

  .primary-actions {
    margin-bottom: 0.85rem;
  }

  .primary-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--accent);
    padding: 0.55rem 1rem;
    background: var(--surface);
    border-radius: 4px;
    border: 1px solid var(--accent);
    transition: all 0.15s ease;
  }
  .primary-card:hover .primary-btn { background: var(--accent); color: #fff; }

  .primary-reassurance {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--muted);
    line-height: 1.5;
    margin: 0;
  }

  /* Corner marks (smaller now since the card is denser) */
  .reg-mark {
    position: absolute;
    width: 9px;
    height: 9px;
    pointer-events: none;
  }
  .reg-mark::before, .reg-mark::after {
    content: "";
    position: absolute;
    background: var(--accent);
  }
  .reg-mark::before { width: 9px; height: 1.5px; top: 50%; left: 0; }
  .reg-mark::after { width: 1.5px; height: 9px; left: 50%; top: 0; }
  .reg-tl { top: 6px; left: 6px; }
  .reg-tr { top: 6px; right: 6px; }
  .reg-bl { bottom: 6px; left: 6px; }
  .reg-br { bottom: 6px; right: 6px; }

  /* ============================================
     TIP block — guidance for better first messages
     ============================================ */
  .tip {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1rem;
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    background: var(--bg-soft);
    border-radius: 6px;
    border-left: 2px solid var(--accent);
  }
  .tip-label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    padding-top: 0.15rem;
  }
  .tip p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--ink-2);
    line-height: 1.55;
  }

  /* ============================================
     SECONDARY CARD - calendar
     ============================================ */
  .secondary-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.1rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    margin-bottom: 2rem;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .secondary-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
    color: inherit;
  }

  .secondary-text { display: flex; flex-direction: column; gap: 0.15rem; }
  .secondary-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .secondary-action {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
  }
  .secondary-card:hover .secondary-action { color: var(--accent); }
  .secondary-hint {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    margin-top: 0.1rem;
  }
  .secondary-icon { color: var(--accent); flex-shrink: 0; }

  /* ============================================
     OTHER CHANNELS
     ============================================ */
  .other-channels {
    padding: 1.25rem 0;
    border-top: 1px dashed var(--rule);
    border-bottom: 1px dashed var(--rule);
    margin-bottom: 2rem;
  }
  .other-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted);
    margin-bottom: 0.85rem;
  }
  .other-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .other-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--ink);
    text-decoration: none;
    padding: 0.25rem 0;
  }
  .other-list a:hover { color: var(--accent); }
  .ch-key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    height: 22px;
    padding: 0 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--muted);
    background: var(--bg-soft);
    border: 1px solid var(--rule);
    border-radius: 3px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .location {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--muted);
    text-align: center;
    line-height: 1.6;
    max-width: 38rem;
    margin: 0 auto;
  }

  @media (max-width: 700px) {
    .fit-row { grid-template-columns: 1fr; gap: 0.2rem; }
    .tip { grid-template-columns: 1fr; gap: 0.5rem; }
    .secondary-card { gap: 1rem; padding: 1rem; }
    .secondary-icon { width: 24px; height: 24px; }
  }

  /* Touch targets — minimum 44px on coarse pointers */
  @media (pointer: coarse) {
    .other-list a { min-height: 44px; }
  }
</style>
