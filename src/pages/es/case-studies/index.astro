---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { localizedPath } from '../../../i18n/utils';

const lang = 'es';
const all = await getCollection('case-studies', ({ id }) => id.startsWith('es/'));
const sorted = all.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Casos" description="Análisis profundos de arquitectura AWS, respuesta a incidentes e ingeniería a escala." lang={lang}>
  <section class="container-narrow">
    <header class="page-head">
      <span class="eyebrow">Casos</span>
      <h1>Sistemas reales. Clientes anonimizados.</h1>
      <p class="lead">Cada caso está estructurado igual: contexto, la arquitectura, los problemas difíciles y el resultado — con las métricas que importaron.</p>
    </header>

    <ul class="case-list">
      {sorted.map((cs) => {
        const slug = cs.id.replace(/^es\//, '').replace(/\.md$/, '');
        return (
          <li>
            <a href={localizedPath(lang, `/case-studies/${slug}`)} class="case-item">
              <div class="case-item-meta">
                <span>{cs.data.industry}</span>
                <span class="dot">·</span>
                <span>{cs.data.year}</span>
              </div>
              <h2 class="case-item-title">{cs.data.title}</h2>
              <p class="case-item-summary">{cs.data.summary}</p>
              <div class="case-item-stack">
                {cs.data.stack.slice(0, 6).map((s) => <span class="tag">{s}</span>)}
                {cs.data.stack.length > 6 && <span class="more">+{cs.data.stack.length - 6}</span>}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>

<style>
  .page-head { margin-bottom: 3rem; }
  .page-head h1 { margin-top: 1rem; max-width: 18ch; }
  .page-head .lead { font-size: 1.1rem; color: var(--ink-2); max-width: 36rem; margin-top: 1rem; }

  .case-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem; }

  .case-item {
    display: block;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: 6px;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .case-item:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    color: inherit;
  }

  .case-item-meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  .case-item-meta .dot { margin: 0 0.4rem; color: var(--accent); }

  .case-item-title {
    font-size: 1.35rem;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .case-item-summary { color: var(--ink-2); margin-bottom: 1rem; line-height: 1.55; }

  .case-item-stack { display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: center; }
  .more {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
  }
</style>
